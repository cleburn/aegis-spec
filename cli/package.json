{
  "name": "aegis-cli",
  "version": "0.1.7",
  "description": ".editorconfig for AI agents. Structured governance for any AI agent working in your codebase.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "aegis": "dist/bin/aegis.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && cp src/schemas/*.json dist/src/schemas/",
    "prepublishOnly": "npm run build",
    "dev": "tsx bin/aegis.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "governance",
    "cli",
    "developer-tools",
    "claude",
    "codex",
    "copilot",
    "agentpolicy"
  ],
  "author": "Cleburn Walker",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleburn/aegis"
  },
  "homepage": "https://github.com/cleburn/aegis",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
